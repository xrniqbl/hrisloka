# ============================================================
# HRIS Loka — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git!
# ============================================================

# Supabase (Required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# PWA Push Notifications (Required for push notifs)
# Generate VAPID keys: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key-here

# ── AI Features ─────────────────────────────────────────────
# Gemini AI — Smart Review Generator
# Get free API key: https://aistudio.google.com/app/apikey
# NOTE: In production, move this call to a Vercel Serverless Function
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# ── Email Notifications ──────────────────────────────────────
# Resend — 3000 emails/month free
# Signup: https://resend.com
# NOTE: In production, move this call to a Vercel Serverless Function (/api/send-email)
VITE_RESEND_API_KEY=your-resend-api-key-here
VITE_FROM_EMAIL=noreply@yourdomain.com

# ── WhatsApp Notifications ───────────────────────────────────
# Option A: Fonnte (Popular di Indonesia, 500 pesan/bulan gratis)
# Signup: https://fonnte.com
# NOTE: In production, move this call to a Vercel Serverless Function (/api/send-whatsapp)
VITE_FONNTE_TOKEN=your-fonnte-token-here

# -- Cron Job Security --------------------------------------------------
# Generate random string: openssl rand -hex 32
CRON_SECRET=your-random-secret-string-here

# Option B: Meta WhatsApp Business API
VITE_WA_BUSINESS_TOKEN=your-meta-wa-business-token-here
VITE_WA_PHONE_ID=your-wa-phone-id-here

# ── Bank Validation ───────────────────────────────────────────
# API.co.id — Bank list for payslip/employee profile
VITE_BANK_VALIDATION_API_KEY=your-api-co-id-key-here
